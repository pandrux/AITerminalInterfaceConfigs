// config.kdl — Zellij base configuration
// Repo: github.com/pandrux/AITerminalInterfaceConfigs

// Theme — Everforest Dark (built-in)
theme "everforest-dark"

// Default shell
default_shell "bash"

// Scrollback
scroll_buffer_size 10000

// Copy to system clipboard
copy_on_select true

// Disable session resurrection prompt on exit
session_serialization false

// Keybindings — direct chord for sync-all-panes (broadcast mode)
// F9 toggles: when on, keystrokes go to every pane in the tab.
// F-keys are not intercepted by TUI apps like Claude/Codex/Gemini.
keybinds {
    shared_except "locked" {
        bind "F9" { ToggleActiveSyncTab; }
    }
}
